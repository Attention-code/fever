<script>
  import gsap from 'gsap';

  const container = document.getElementById('infinite-gallery')!;
  const inner = document.getElementById('gallery-inner')!;
  const items = inner.querySelectorAll('.gallery-item');
  const itemWidth = (items[0] as HTMLElement).offsetWidth + 20; // width + margin
  const halfCount = items.length / 2;
  const halfWidth = halfCount * itemWidth;

  let isDragging = false;
  let startX = 0;
  let scrollLeft = 0;
  let currentX = 0;
  let lastDx = 0;
  let lastMoveTime = 0;

  // 鼠标拖拽
  container.addEventListener('mousedown', (e) => {
    isDragging = true;
    startX = e.pageX;
    scrollLeft = currentX;
    lastDx = 0;
    lastMoveTime = Date.now();
    container.style.cursor = 'grabbing';
  });

  container.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    e.preventDefault();
    const dx = e.pageX - startX;
    lastDx = dx - (currentX - scrollLeft);
    lastMoveTime = Date.now();
    currentX = scrollLeft + dx;
    applyPosition();
  });

  window.addEventListener('mouseup', () => {
    if (isDragging) {
      isDragging = false;
      container.style.cursor = 'grab';
      // 惯性效果
      const velocity = lastDx;
      if (Math.abs(velocity) > 2) {
        gsap.to({ x: currentX }, {
          x: currentX + velocity * 15,
          duration: 1.2,
          ease: 'power3.out',
          onUpdate: function() {
            currentX = this.targets()[0].x;
            applyPosition();
          }
        });
      }
    }
  });

  // 触摸拖拽
  container.addEventListener('touchstart', (e) => {
    isDragging = true;
    startX = e.touches[0].pageX;
    scrollLeft = currentX;
    lastDx = 0;
  }, { passive: true });

  container.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const dx = e.touches[0].pageX - startX;
    lastDx = dx - (currentX - scrollLeft);
    currentX = scrollLeft + dx;
    applyPosition();
  }, { passive: true });

  container.addEventListener('touchend', () => {
    isDragging = false;
    // 触摸惯性
    const velocity = lastDx;
    if (Math.abs(velocity) > 2) {
      gsap.to({ x: currentX }, {
        x: currentX + velocity * 10,
        duration: 0.8,
        ease: 'power3.out',
        onUpdate: function() {
          currentX = this.targets()[0].x;
          applyPosition();
        }
      });
    }
  });

  function applyPosition() {
    // 无限循环：边界穿越
    if (currentX < -halfWidth) {
      currentX += halfWidth;
      scrollLeft += halfWidth;
    }
    if (currentX > 0) {
      currentX -= halfWidth;
      scrollLeft -= halfWidth;
    }
    gsap.set(inner, { x: currentX });
  }

  // 自动缓慢漂移
  let autoScroll: ReturnType<typeof setInterval> | null = null;

  function startAutoScroll() {
    autoScroll = setInterval(() => {
      if (!isDragging) {
        currentX -= 0.5;
        applyPosition();
      }
    }, 16);
  }

  // 只在可视区域内自动滚动
  const galleryObserver = new IntersectionObserver(([entry]) => {
    if (entry.isIntersecting) {
      startAutoScroll();
    } else if (autoScroll) {
      clearInterval(autoScroll);
      autoScroll = null;
    }
  }, { threshold: 0.1 });

  galleryObserver.observe(container);
</script>
